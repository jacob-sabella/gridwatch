*.p12
*.pfx
id_rsa
id_ed25519
*_token*
!*_token*.example
api_key
api_key.txt
*.api-key
service_keys
.service_keys

# ---- User-specific config overrides ----
# The shipped example is configs/gridwatch.example.yaml — live configs should
# live outside the repo (bind-mounted or in /opt on the host).
/gridwatch.yaml
/configs/gridwatch.yaml
!/configs/gridwatch.example.yaml

