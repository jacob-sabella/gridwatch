# Caddy reverse proxy for gridwatch.
# Caddy handles SSE correctly out of the box — no tweaks needed.

gridwatch.your.domain {
	reverse_proxy gridwatch:8080 {
		# SSE: make sure intermediaries don't buffer.
		header_up X-Accel-Buffering no
	}

	# Optional: gzip HTML/JSON responses. Static CSS/JS are already
	# small enough that compression isn't a huge win, but it doesn't hurt.
	encode gzip
}
